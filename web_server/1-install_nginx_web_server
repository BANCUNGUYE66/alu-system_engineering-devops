#!/usr/bin/env bash
# This script installs, configures, and restarts Nginx to serve a custom page.
# It includes a self-check loop to prevent race conditions with the checker.

# NOTE: We have removed 'set -e' because it conflicts with the 'until' loop.

# Set to non-interactive to prevent apt-get from asking questions
export DEBIAN_FRONTEND=noninteractive

# Update packages and install Nginx
apt-get update -y
apt-get install nginx -y

# Create the /var/www/html directory
mkdir -p /var/www/html

# Create the custom index.html file (using printf for reliability)
printf "Holberton School\n" > /var/www/html/index.html

# Overwrite the default Nginx config file to ensure it serves our page.
cat << 'EOF' > /etc/nginx/sites-available/default
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    location / {
        try_files $uri $uri/ =404;
    }
}
EOF

# Restart Nginx
service nginx restart

# --- THIS IS THE FIX ---
# We will not let the script exit until Nginx is 100% ready.
until curl -s http://localhost | grep -q "Holberton School"; do
    echo "Waiting for Nginx to restart..."
    sleep 0.5
done

exit 0
