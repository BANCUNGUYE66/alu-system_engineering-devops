#!/usr/bin/env bash
# This script installs and configures Nginx to serve a custom page on port 80.

# Update the package index
apt-get update -y

# Install nginx (if not already installed)
apt-get install nginx -y

# Define the custom content
CONTENT="Holberton School for the win!"

# Overwrite the default Nginx index.html file
echo "$CONTENT" > /var/www/html/index.html

# ALSO overwrite the default .nginx-debian.html file, just in case
# Nginx is configured to look for this file first.
echo "$CONTENT" > /var/www/html/index.nginx-debian.html

# Restart the Nginx service to apply changes
# Using 'service' which is the standard wrapper for init.d scripts
service nginx restart

exit 0
