#!/usr/bin/env bash
# Installs and configures Nginx to serve a custom page.

# Update package lists
apt-get update -y

# Install Nginx
apt-get install -y nginx

# Create a simple custom index.html page
echo "Holberton School for the win!" > /var/www/html/index.html

# Restart the Nginx service (using 'service' as 'systemctl' is not allowed)
service nginx restart

exit 0
```

