#!/usr/bin/env bash
# This script installs and configures Nginx, ensuring all directories exist.

# Set to non-interactive to prevent apt-get from asking questions
export DEBIAN_FRONTEND=noninteractive

# Update packages and install Nginx
apt-get update -y
apt-get install nginx -y

# --- THIS IS THE FIX ---
# Create the /var/www/html directory if it does not exist
# Your error log "No such file or directory" proves this is needed.
mkdir -p /var/www/html

# Create the new index.html file
echo "Holberton School" > /var/www/html/index.html
    
# Just in case, also overwrite the other default file
echo "Holberton School" > /var/www/html/index.nginx-debian.html

# Restart Nginx
service nginx restart

exit 0
