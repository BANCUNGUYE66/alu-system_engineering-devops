#!/usr/bin/env bash
# This script installs, configures, and restarts Nginx to serve a custom page.

# Set to non-interactive to prevent apt-get from asking questions
export DEBIAN_FRONTEND=noninteractive

# Update packages and install Nginx
apt-get update -y
apt-get install nginx -y

# Create the /var/www/html directory
mkdir -p /var/www/html

# Create the custom index.html file
echo "Holberton School" > /var/www/html/index.html

# Overwrite the default Nginx config file to ensure it serves our page.
cat << 'EOF' > /etc/nginx/sites-available/default
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    location / {
        try_files $uri $uri/ =404;
    }
}
EOF

# Restart Nginx to apply all changes
service nginx restart

exit 0
