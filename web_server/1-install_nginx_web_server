#!/usr/bin/env bash
# This script installs and configures Nginx to serve a custom page on port 80.

# Update packages and install Nginx
apt-get update -y
apt-get install nginx -y

# Define the HTML content
CONTENT="Holberton School for the win!"

# Create the new index.html file
# Using printf is more reliable than echo
printf "%s\n" "$CONTENT" > /var/www/html/index.html

# Also overwrite the default nginx file just in case
printf "%s\n" "$CONTENT" > /var/www/html/index.nginx-debian.html

# Restart Nginx
service nginx restart

# Add a 1-second pause to allow Nginx to fully restart
# This helps prevent a race condition with the checker.
sleep 1

exit 0
