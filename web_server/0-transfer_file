#!/usr/bin/env bash
# Transfers a file to a remote server using scp

# Check if the number of arguments is exactly 4
if [ $# -ne 4 ]; then
    # Print the usage message if not enough arguments are provided
    echo "Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY"
    exit 1
fi

# Assign arguments to variables for clarity
FILE_PATH="$1"
IP="$2"
USER="$3"
SSH_KEY="$4"

# Use scp to transfer the file
# -i: Specifies the private key to use
# -o StrictHostKeyChecking=no: Disables the host key check (as required)
scp -i "$SSH_KEY" -o "StrictHostKeyChecking=no" "$FILE_PATH" "$USER"@"$IP":~/
```

